{"name":"t:sections.footer.name","type":"footer","sections":{"custom_liquid_FtBhpA":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<style>\n\/* =========================================\n   ZARIYA — LUX CONTACT (FINAL \/ MOBILE-SAFE)\n   Apple-grade • Premium • Click-safe\n   ========================================= *\/\n\n.lux-contact{\n  position:fixed;\n  right:18px;\n  bottom:18px;\n  z-index:99999;\n  font-family:-apple-system,BlinkMacSystemFont,\"Segoe UI\",sans-serif;\n  transition:\n    transform .35s cubic-bezier(.22,1,.36,1),\n    opacity .25s ease;\n  will-change: transform, opacity;\n  touch-action: manipulation;\n}\n\n\/* ---------- TOGGLE ---------- *\/\n.lux-toggle{\n  width:64px;\n  height:64px;\n  border-radius:50%;\n  background:linear-gradient(180deg,#1ec06a,#25D366);\n  box-shadow:\n    0 14px 32px rgba(0,0,0,.35),\n    inset 0 1px 0 rgba(255,255,255,.35);\n  border:none;\n  cursor:pointer;\n  display:grid;\n  place-items:center;\n  transition:\n    transform .15s ease,\n    box-shadow .15s ease;\n}\n\n.lux-toggle:active{\n  transform:scale(.94);\n  box-shadow:0 6px 18px rgba(0,0,0,.35);\n}\n\n\/* ---------- OPTIONS ---------- *\/\n.lux-options{\n  position:absolute;\n  bottom:82px;\n  right:0;\n  display:flex;\n  flex-direction:column;\n  gap:14px;\n  opacity:0;\n  transform:translateY(14px);\n  pointer-events:none;\n  transition:\n    opacity .25s ease,\n    transform .25s cubic-bezier(.22,1,.36,1);\n}\n\n.lux-contact.open .lux-options{\n  opacity:1;\n  transform:translateY(0);\n  pointer-events:auto;\n}\n\n\/* ---------- ITEMS ---------- *\/\n.lux-item{\n  display:flex;\n  align-items:center;\n  gap:14px;\n  padding:14px 18px;\n  border-radius:18px;\n  background:#fff;\n  box-shadow:0 18px 40px rgba(0,0,0,.3);\n  text-decoration:none;\n  color:#111;\n  font-weight:600;\n  letter-spacing:.2px;\n  transition:transform .2s ease;\n}\n\n.lux-item:active{\n  transform:scale(.97);\n}\n\n\/* ---------- ICONS (PREMIUM) ---------- *\/\n.lux-icon{\n  width:44px;\n  height:44px;\n  border-radius:50%;\n  display:grid;\n  place-items:center;\n  flex-shrink:0;\n  box-shadow:\n    inset 0 1px 1px rgba(255,255,255,.45),\n    inset 0 -1px 2px rgba(0,0,0,.25),\n    0 10px 22px rgba(0,0,0,.28);\n}\n\n.lux-wa .lux-icon{\n  background:\n    radial-gradient(circle at 30% 30%, rgba(255,255,255,.55), transparent 45%),\n    linear-gradient(180deg,#29e07b,#1fb25f);\n}\n\n.lux-ig .lux-icon{\n  background:\n    radial-gradient(circle at 30% 30%, rgba(255,255,255,.45), transparent 50%),\n    linear-gradient(135deg,#833ab4,#fd1d1d,#fcb045);\n}\n\n.lux-label{\n  font-size:14px;\n  white-space:nowrap;\n}\n\n\/* ---------- MOBILE ---------- *\/\n@media(max-width:420px){\n  .lux-label{display:none}\n  .lux-item{padding:12px}\n}\n\n\/* ---------- HIDE WHEN FILTER DRAWER OPEN ---------- *\/\n@media (max-width: 989px) {\n  body.mobile-facets-open .lux-contact{\n    opacity:0;\n    transform:translateY(24px);\n    pointer-events:none;\n  }\n}\n\n\/* ---------- SCROLL COLLAPSE ---------- *\/\n.lux-contact.is-scrolling{\n  opacity:.85;\n  transform:translateY(12px);\n}\n<\/style>\n\n<div class=\"lux-contact\" id=\"luxContact\">\n  <div class=\"lux-options\">\n\n    <!-- Instagram -->\n    <a href=\"https:\/\/www.instagram.com\/zariya.wear\/\"\n       target=\"_blank\"\n       rel=\"noopener\"\n       class=\"lux-item lux-ig\">\n      <span class=\"lux-icon\">\n        <svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\">\n          <rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"5\" stroke=\"#fff\" stroke-width=\"2\"\/>\n          <circle cx=\"12\" cy=\"12\" r=\"4\" stroke=\"#fff\" stroke-width=\"2\"\/>\n          <circle cx=\"17\" cy=\"7\" r=\"1.2\" fill=\"#fff\"\/>\n        <\/svg>\n      <\/span>\n      <span class=\"lux-label\">Instagram<\/span>\n    <\/a>\n\n    <!-- WhatsApp -->\n    <a href=\"https:\/\/wa.me\/916399008999?text=Hi%20I%20want%20to%20shop%20from%20Zariya\"\n       target=\"_blank\"\n       rel=\"noopener\"\n       class=\"lux-item lux-wa\">\n      <span class=\"lux-icon\">\n        <svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\">\n          <path d=\"M12 3a9 9 0 0 0-7.8 13.5L3 21l4.7-1.2A9 9 0 1 0 12 3z\"\n                stroke=\"#fff\" stroke-width=\"2\"\/>\n          <path d=\"M9.5 9.5c.4-.4.7-.4 1.1 0l1 1c.4.4.4.7 0 1.1l-.5.5c.7 1.3 1.8 2.4 3.1 3.1l.5-.5c.4-.4.7-.4 1.1 0l1 1c.4.4.4.7 0 1.1-.7.7-1.7.9-2.6.5-2.2-1-4.1-2.9-5.1-5.1-.4-.9-.2-1.9.5-2.6z\"\n                fill=\"#fff\"\/>\n        <\/svg>\n      <\/span>\n      <span class=\"lux-label\">WhatsApp<\/span>\n    <\/a>\n\n  <\/div>\n\n  <button class=\"lux-toggle\" id=\"luxToggle\" aria-label=\"Contact\">\n    <svg width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\">\n      <path d=\"M21 12c0 4.4-4 8-9 8-1.3 0-2.6-.2-3.8-.7L3 21l1.9-4.6A7.7 7.7 0 0 1 3 12c0-4.4 4-8 9-8s9 3.6 9 8z\"\n            stroke=\"#fff\" stroke-width=\"2\"\/>\n    <\/svg>\n  <\/button>\n<\/div>\n\n<script>\n(() => {\n  const lux = document.getElementById(\"luxContact\");\n  const toggle = document.getElementById(\"luxToggle\");\n  if (!lux || !toggle) return;\n\n  toggle.addEventListener(\"click\", e => {\n    e.stopPropagation();\n    lux.classList.toggle(\"open\");\n  });\n\n  document.addEventListener(\"click\", e => {\n    if (!lux.contains(e.target)) lux.classList.remove(\"open\");\n  });\n\n  let scrollTimer;\n  window.addEventListener(\"scroll\", () => {\n    lux.classList.add(\"is-scrolling\");\n    lux.classList.remove(\"open\");\n    clearTimeout(scrollTimer);\n    scrollTimer = setTimeout(() => {\n      lux.classList.remove(\"is-scrolling\");\n    }, 180);\n  }, { passive:true });\n\n  const mo = new MutationObserver(() => {\n    lux.classList.remove(\"open\");\n  });\n\n  mo.observe(document.body, {\n    attributes:true,\n    attributeFilter:[\"class\"]\n  });\n})();\n<\/script>","color_scheme":"scheme-3","padding_top":0,"padding_bottom":0}},"footer":{"type":"footer","settings":{"color_scheme":"scheme-3","newsletter_enable":false,"newsletter_heading":"","enable_follow_on_shop":false,"show_social":false,"enable_country_selector":true,"enable_language_selector":true,"payment_enable":false,"show_policy":false,"margin_top":0,"padding_top":0,"padding_bottom":24}}},"order":["custom_liquid_FtBhpA","footer"]}