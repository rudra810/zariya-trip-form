<section class="hero">
  <div class="container hero-content">
    {% if section.settings.eyebrow != blank %}
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    <h1>{{ section.settings.heading }}</h1>

    {% if section.settings.subtext != blank %}
      <p class="subtext">{{ section.settings.subtext }}</p>
    {% endif %}

    {% if section.settings.button_label != blank and section.settings.button_link != blank %}
      <a class="btn" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "STREET. INTENTIONAL. UNAPOLOGETIC."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
