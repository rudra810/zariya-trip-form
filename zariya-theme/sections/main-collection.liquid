<section class="section collection-hero">
  <div class="container collection-hero-grid">
    <div class="reveal">
      <p class="eyebrow">{{ section.settings.eyebrow | default: 'Full catalog' }}</p>
      <h1>{{ collection.title | default: section.settings.heading }}</h1>
      <p class="hero-text">{{ collection.description | default: section.settings.description }}</p>
    </div>
    <article class="panel reveal collection-hero-panel">
      <p class="eyebrow">{{ section.settings.panel_eyebrow }}</p>
      <p>{{ section.settings.panel_text }}</p>
    </article>
  </div>
</section>

<section class="section section-tight">
  <div class="container collection-toolbar">
    <label class="field search-field">
      <span class="eyebrow">Search</span>
      <input type="search" placeholder="Search products..." data-collection-search>
    </label>
    <label class="field sort-field">
      <span class="eyebrow">Sort by</span>
      <select id="sort-select" data-sort-select>
        {% for option in collection.sort_options %}
          <option value="{{ option.value }}" {% if collection.sort_by == option.value %}selected{% endif %}>{{ option.name }}</option>
        {% endfor %}
      </select>
    </label>
  </div>
</section>

<section class="section">
  <div class="container collection-layout">
    <aside class="filter-panel panel reveal">
      <p class="eyebrow">Filter</p>
      <div class="filter-stack">
        <a class="chip {% unless current_tags %}is-active{% endunless %}" href="{{ collection.url }}">All</a>
        {% for tag in collection.all_tags %}
          <a class="chip {% if current_tags contains tag %}is-active{% endif %}" href="{{ collection.url }}/{{ tag | handle }}">{{ tag }}</a>
        {% endfor %}
      </div>
    </aside>
    <section>
      <div class="results-bar">
        <p class="eyebrow" data-collection-summary>{{ collection.products_count }} pieces</p>
        <a class="text-link" href="/pages/contact">Need help choosing?</a>
      </div>
      <div id="collection-grid" class="product-grid product-grid-full">
        {% paginate collection.products by 12 %}
          {% for product in collection.products %}
            {% render 'product-card', product: product %}
          {% endfor %}
        {% endpaginate %}
      </div>
      {% if paginate.pages > 1 %}
        <div class="pagination">
          {{ paginate | default_pagination }}
        </div>
      {% endif %}
    </section>
  </div>
</section>

<script>
  // Sort functionality
  document.addEventListener('DOMContentLoaded', function() {
    const sortSelect = document.querySelector('[data-sort-select]');
    if (sortSelect) {
      sortSelect.addEventListener('change', function() {
        const url = new URL(window.location.href);
        url.searchParams.set('sort_by', this.value);
        window.location.href = url.toString();
      });
    }
  });
</script>

{% schema %}
{
  "name": "Collection Template",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Full catalog"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Default heading",
      "default": "Seasonless essentials, built like a drop."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Default description",
      "default": "Explore our complete range of premium streetwear — from heavyweight tees to statement hoodies, every piece is crafted with intention."
    },
    {
      "type": "text",
      "id": "panel_eyebrow",
      "label": "Panel eyebrow",
      "default": "Catalog snapshot"
    },
    {
      "type": "textarea",
      "id": "panel_text",
      "label": "Panel text",
      "default": "Each piece is designed as a limited edition, built with premium materials and available while stocks last."
    }
  ]
}
{% endschema %}
