<section class="section lookbook-banner">
  <div class="container">
    <div class="lookbook-grid">
      <div class="lookbook-text reveal">
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        <h2>{{ section.settings.heading }}</h2>
        <p class="lookbook-desc">{{ section.settings.description }}</p>
        <div class="lookbook-stats">
          <div>
            <strong>{{ section.settings.stat_1_value }}</strong>
            <span>{{ section.settings.stat_1_label }}</span>
          </div>
          <div>
            <strong>{{ section.settings.stat_2_value }}</strong>
            <span>{{ section.settings.stat_2_label }}</span>
          </div>
          <div>
            <strong>{{ section.settings.stat_3_value }}</strong>
            <span>{{ section.settings.stat_3_label }}</span>
          </div>
        </div>
        {% if section.settings.cta_text != blank %}
          <a class="button button-solid" href="{{ section.settings.cta_link | default: '/collections/all' }}">{{ section.settings.cta_text }}</a>
        {% endif %}
      </div>
      <div class="lookbook-visual reveal">
        <div class="lookbook-card lookbook-card-main">
          <p class="eyebrow">{{ section.settings.card_eyebrow }}</p>
          <h3>{{ section.settings.card_heading }}</h3>
          <p>{{ section.settings.card_text }}</p>
        </div>
        <div class="lookbook-card lookbook-card-accent">
          <span class="lookbook-quote">"</span>
          <p>{{ section.settings.quote_text }}</p>
          <span class="lookbook-author">— {{ section.settings.quote_author }}</span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lookbook Banner",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Why Zariya"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Not fast fashion. Built to last."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Every piece is cut from 240 GSM premium cotton, double-stitched at stress points, and designed to hold its shape through hundreds of washes. We don't chase trends — we build wardrobe anchors."
    },
    {
      "type": "text",
      "id": "stat_1_value",
      "label": "Stat 1 value",
      "default": "240 GSM"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 label",
      "default": "Premium cotton"
    },
    {
      "type": "text",
      "id": "stat_2_value",
      "label": "Stat 2 value",
      "default": "Limited"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 label",
      "default": "Edition drops"
    },
    {
      "type": "text",
      "id": "stat_3_value",
      "label": "Stat 3 value",
      "default": "24-48h"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 label",
      "default": "Dispatch time"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "Explore the collection"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    },
    {
      "type": "text",
      "id": "card_eyebrow",
      "label": "Card eyebrow",
      "default": "Craftsmanship"
    },
    {
      "type": "text",
      "id": "card_heading",
      "label": "Card heading",
      "default": "Made to move with you."
    },
    {
      "type": "textarea",
      "id": "card_text",
      "label": "Card text",
      "default": "From structured shoulders to drop-cut hems — every silhouette is designed for comfort without compromising on form."
    },
    {
      "type": "textarea",
      "id": "quote_text",
      "label": "Quote text",
      "default": "Zariya pieces feel like they were made just for me. The weight, the fit, the detailing — nothing else compares at this price."
    },
    {
      "type": "text",
      "id": "quote_author",
      "label": "Quote author",
      "default": "A Zariya customer"
    }
  ],
  "presets": [
    {
      "name": "Lookbook Banner"
    }
  ]
}
{% endschema %}
